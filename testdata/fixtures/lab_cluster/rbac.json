{
  "cluster_roles": [
    {
      "name": "cluster-admin",
      "rules": [
        {
          "verbs": ["*"],
          "resources": ["*"],
          "api_groups": ["*"]
        }
      ]
    },
    {
      "name": "edit",
      "rules": [
        {
          "verbs": ["get", "list", "watch", "create", "update", "patch", "delete"],
          "resources": ["deployments", "daemonsets", "statefulsets", "pods", "jobs", "cronjobs"],
          "api_groups": ["apps", "batch", ""]
        }
      ]
    }
  ],
  "roles": [
    {
      "namespace": "storefront",
      "name": "view",
      "rules": [
        {
          "verbs": ["get", "list", "watch"],
          "resources": ["pods", "services", "configmaps"],
          "api_groups": [""]
        }
      ]
    }
  ],
  "cluster_role_bindings": [
    {
      "name": "harrierops-kube-lab-cluster-admin",
      "role_ref": {
        "kind": "ClusterRole",
        "name": "cluster-admin"
      },
      "subjects": [
        {
          "kind": "ServiceAccount",
          "name": "fox-admin",
          "namespace": "default"
        }
      ]
    }
  ],
  "role_bindings": [
    {
      "namespace": "storefront",
      "name": "web-edit",
      "role_ref": {
        "kind": "ClusterRole",
        "name": "edit"
      },
      "subjects": [
        {
          "kind": "ServiceAccount",
          "name": "web",
          "namespace": "storefront"
        }
      ]
    },
    {
      "namespace": "storefront",
      "name": "view-only",
      "role_ref": {
        "kind": "Role",
        "name": "view"
      },
      "subjects": [
        {
          "kind": "User",
          "name": "analyst@example.com"
        }
      ]
    }
  ],
  "issues": []
}
